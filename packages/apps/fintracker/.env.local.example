# Copy to .env.local (never commit .env.local). See CLAUDE.md and .cursor/rules/google-oauth-env.mdc

# Required for HttpOnly session + gated /api/gas-proxy (32+ chars, e.g. openssl rand -base64 32)
SESSION_SECRET=

VITE_GOOGLE_CLIENT_ID=
VITE_GAS_URL=
VITE_API_TOKEN=
VITE_ALLOWED_EMAILS=

# Server-only PIN (preferred over VITE_APP_PASSWORD). Optional idle lock.
# APP_PASSWORD=

# When allowlist has multiple emails, set explicitly so PIN-only unlock binds the right user:
# PIN_SESSION_EMAIL=

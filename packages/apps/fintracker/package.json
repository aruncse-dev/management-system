  },
  "devDependencies": {
    "typescript": "workspace:*",
    "eslint": "workspace:*",
    "eslint-config-next": "workspace:*",
    "@types/node": "workspace:*",
    "@types/react": "workspace:*",
    "@types/react-dom": "workspace:*",
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0"

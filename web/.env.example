# =============================================================================
# Local dev — single file for the monorepo (copy to .env in this folder)
# =============================================================================
# Used by:
#   - packages/apps/fintracker & vault (Next) via packages/apps/resolve-google-env.cjs
#   - web/ Vite app (VITE_*)
# Create:  cp .env.example .env   then fill secrets. Restart dev after changes.
# Google OAuth: set VITE_GOOGLE_CLIENT_ID (and optionally duplicate as NEXT_PUBLIC_GOOGLE_CLIENT_ID).
# =============================================================================

# Google Sheet ID (for GAS backend)
VITE_SHEET_ID=your-google-sheet-id

# GAS deployment URL (Apps Script web app exec URL)
VITE_GAS_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# API base URL for frontend requests
# Dev: /gas-proxy (uses Vite dev server proxy)
# Prod: https://your-worker.workers.dev (Cloudflare Worker proxy to GAS)
VITE_API_URL=/gas-proxy

# Google OAuth Client ID (required for Fintracker/Vault Google sign-in locally)
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
# Optional duplicate for Next-only tooling (same value as above; usually not needed)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# App kind for deployment
# auto = use local path detection
# vault = always render vault
# fintracker = always render finance
VITE_APP_KIND=auto

# Allowed email addresses (comma-separated)
VITE_ALLOWED_EMAILS=yourname@gmail.com,spouse@gmail.com

# App password for the local lock screen
VITE_APP_PASSWORD=1234

# API token for authentication (optional, set in GAS PropertiesService)
VITE_API_TOKEN=

# Gemini API Key for AI features (optional)
VITE_GEMINI_KEY=

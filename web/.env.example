# Google Sheet ID (for GAS backend)
VITE_SHEET_ID=your-google-sheet-id

# GAS deployment URL (Apps Script web app exec URL)
VITE_GAS_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# API base URL for frontend requests
# Dev: /gas-proxy (uses Vite dev server proxy)
# Prod: https://your-worker.workers.dev (uses Cloudflare Worker)
VITE_API_URL=/gas-proxy

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com

# Allowed email addresses (comma-separated)
VITE_ALLOWED_EMAILS=yourname@gmail.com,spouse@gmail.com

# App password for the local lock screen
VITE_APP_PASSWORD=1234

# API token for authentication (optional, set in GAS PropertiesService)
VITE_API_TOKEN=

# Gemini API Key for AI features (optional)
VITE_GEMINI_KEY=

{
  "$schema": "https://turbo.build/schema.json",
  "version": "1",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": [".eslintcache"]
    },
    "type-check": {
      "outputs": [".tsbuildinfo"]
    }
  }
}
